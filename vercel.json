{
  "version": 2,
  "builds": [
    { "src": "api/sentiment.py", "use": "@vercel/python" },
    { "src": "index.html",       "use": "@vercel/static"  }
  ],
  "routes": [
    { "src": "/api/sentiment", "dest": "/api/sentiment.py" },
    { "src": "/",              "dest": "/index.html"       }
  ]
}
